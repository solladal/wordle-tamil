# Base URL of the words API (Cloudflare Worker). Leave unset to use the bundled
# fallback word lists in src/util/words.js (no remote fetching, no daily/weekly updates).
# Example: https://wordle-tamil-words-api.<your-subdomain>.workers.dev
REACT_APP_WORDS_API_BASE=

# Real env files used by this project (see Create React App's env file docs):
#   .env.production            - committed. The real deployed Worker URL (not a secret).
#   .env.development.local     - gitignored, per-machine. Points at your local `wrangler dev`
#                                 Worker (e.g. http://localhost:8787) while running `npm start`.
# Do NOT create a plain ".env.local" for this - CRA loads ".local" files before
# ".env.production" during `npm run build`, so it would silently override the real
# production URL in production builds too.
